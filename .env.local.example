# Your Google Sheet ID (from the URL: /spreadsheets/d/THIS_PART/edit)
NEXT_PUBLIC_SHEET_ID=1mdH-p1m1uFCbXHwQ8aOHXxBWGKiqj9eIdWoi_raJYa8

# Google Sheets API key (for the write endpoint — create in Google Cloud Console)
# Only needed for the /api/newsletter POST endpoint
SHEETS_API_KEY=your_google_api_key_here

# Secret header sent by n8n to authenticate the webhook POST
# Set this to any random string, then add it to n8n's POST to Frontend node
# as header: x-webhook-secret: <this value>
WEBHOOK_SECRET=change_me_to_a_random_secret
